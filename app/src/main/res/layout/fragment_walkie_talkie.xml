<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- User count row -->
    <com.google.android.material.chip.Chip
        android:id="@+id/chip_user_count"
        style="@style/Widget.Material3.Chip.Assist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/wt_no_users"
        app:chipIcon="@android:drawable/ic_menu_my_calendar"
        android:checkable="false" />

    <!-- Speaking indicator -->
    <TextView
        android:id="@+id/tv_speaking"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?colorPrimary"
        android:visibility="invisible"
        android:text="@string/wt_someone_speaking" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- PTT button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ptt"
        style="@style/Widget.Material3.Button"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:text="@string/wt_hold_to_talk"
        android:textSize="16sp"
        app:cornerRadius="90dp"
        android:enabled="false" />

    <!-- Talking label -->
    <TextView
        android:id="@+id/tv_ptt_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="?colorOnSurfaceVariant"
        android:text="@string/wt_hold_to_talk_hint" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Leave / Join button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_leave"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/wt_leave_channel"
        android:visibility="gone" />

</LinearLayout>
