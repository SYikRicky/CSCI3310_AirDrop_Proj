<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tab_receive"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Make this device discoverable to receive files"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Antenna / download icon placeholder -->
    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@android:drawable/stat_sys_download"
        android:layout_marginBottom="32dp"
        android:contentDescription="Receive icon" />

    <!-- Dynamic status label -->
    <TextView
        android:id="@+id/tv_receive_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/not_receiving"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Toggle button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle_receive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/start_receiving"
        android:minWidth="200dp" />

    <!-- Action buttons shown after a file is received (initially hidden) -->
    <LinearLayout
        android:id="@+id/layout_file_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_file"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_file"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_downloads"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="@string/btn_open_downloads" />

    </LinearLayout>

</LinearLayout>
