<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Back arrow / header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload to Drive"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pick a file — it will be visible to everyone in the shared drive"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_max_size_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="?colorPrimary"
        android:layout_marginBottom="28dp" />

    <!-- Selected file preview -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected File"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?colorPrimary" />

            <TextView
                android:id="@+id/tv_selected_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="No file selected"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:ellipsize="middle"
                android:singleLine="true" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Pick File button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pick_file"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_pick_file"
        android:layout_marginBottom="12dp" />

    <!-- Upload progress -->
    <ProgressBar
        android:id="@+id/progress_upload"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:layout_marginBottom="6dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_upload_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?colorPrimary"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <!-- Upload button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_find_devices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_upload" />

</LinearLayout>
